<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />

    <% if (error) { %>
        <title>Post Not Found — urbox.ai Blog</title>
        <meta name="description" content="Post not found." />
        <% } else { %>
            <!-- ══════ SEO (Dynamic from Server) ══════ -->
            <title>
                <%= post.title %> — urbox.ai Blog
            </title>
            <meta name="description" content="<%= post.excerpt || '' %>" />
            <link rel="canonical" href="<%= post.fullUrl %>" />

            <!-- Open Graph -->
            <meta property="og:type" content="article" />
            <meta property="og:site_name" content="urbox.ai" />
            <meta property="og:title" content="<%= post.title %> — urbox.ai Blog" />
            <meta property="og:description" content="<%= post.excerpt || '' %>" />
            <meta property="og:url" content="<%= post.fullUrl %>" />
            <meta property="og:image" content="<%= post.coverImage || 'https://urbox.ai/og-image.png' %>" />
            <meta property="article:published_time" content="<%= post.publishedISO %>" />
            <meta property="article:author" content="<%= post.author || 'urbox.ai' %>" />

            <!-- Twitter / X Card -->
            <meta name="twitter:card" content="summary_large_image" />
            <meta name="twitter:site" content="@urboxai" />
            <meta name="twitter:title" content="<%= post.title %> — urbox.ai Blog" />
            <meta name="twitter:description" content="<%= post.excerpt || '' %>" />
            <meta name="twitter:image" content="<%= post.coverImage || 'https://urbox.ai/og-image.png' %>" />

            <!-- JSON-LD Article schema -->
            <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "BlogPosting",
                "headline": "<%= post.title %>",
                "description": "<%= post.excerpt || '' %>",
                "author": { "@type": "Person", "name": "<%= post.author || 'urbox.ai' %>" },
                "publisher": {
                    "@type": "Organization",
                    "name": "urbox.ai",
                    "logo": { "@type": "ImageObject", "url": "https://urbox.ai/logo.png" }
                },
                "datePublished": "<%= post.publishedISO %>",
                "image": "<%= post.coverImage || 'https://urbox.ai/og-image.png' %>",
                "url": "<%= post.fullUrl %>",
                "mainEntityOfPage": { "@type": "WebPage", "@id": "<%= post.fullUrl %>" }
            }
        </script>
            <% } %>

                <!-- Fonts -->
                <link rel="preconnect" href="https://fonts.googleapis.com" />
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
                <link
                    href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Serif+Display:ital@0;1&display=swap"
                    rel="stylesheet" />

                <!-- Styles -->
                <!-- Notice we use absolute paths (/styles/...) so they resolve correctly regardless of the URL path depth (/blog/:slug) -->
                <link rel="stylesheet" href="/styles/base.css" />
                <link rel="stylesheet" href="/sections/navbar/navbar.css" />
                <link rel="stylesheet" href="/sections/footer/footer.css" />
                <link rel="stylesheet" href="/blog/blog.css" />

                <!-- Analytics -->
                <script type="module" src="/scripts/analytics.js"></script>
</head>

<body class="blog-page">

    <!-- ══════ NAVBAR ══════ -->
    <%- include('partials/header') %>

        <!-- ══════ POST CONTENT (Rendered by Server) ══════ -->
        <div id="post-root">
            <% if (error) { %>
                <div class="post-error">
                    <h2>Post not found</h2>
                    <p>
                        <%= error %>
                    </p>
                    <a href="/blog/" style="color:var(--primary);font-weight:600;">← Back to Blog</a>
                </div>
                <% } else { %>
                    <div class="post-header">
                        <a href="/blog/" class="post-back">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Back to Blog
                        </a>
                        <div class="post-eyebrow">
                            <span class="post-category-pill">
                                <%= post.category || 'Article' %>
                            </span>
                            <span class="post-read-time">
                                <%= post.readTime || 5 %> min read
                            </span>
                        </div>
                        <h1 class="post-title">
                            <%= post.title %>
                        </h1>
                        <p class="post-excerpt">
                            <%= post.excerpt || '' %>
                        </p>
                        <div class="post-byline">
                            <div class="post-byline-avatar">
                                <%= post.authorInitial %>
                            </div>
                            <div>
                                <div class="post-byline-name">
                                    <%= post.author || 'urbox.ai' %>
                                </div>
                                <div class="post-byline-date">
                                    <%= post.publishedAt ? post.publishedAt.toLocaleDateString("en-US", {
                                        year: "numeric" , month: "long" , day: "numeric" }) : '' %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="post-cover-banner">
                        <div class="cover-gradient">
                            <div class="cover-blur-circle c1"></div>
                            <div class="cover-blur-circle c2"></div>
                        </div>
                    </div>

                    <article class="post-content">
                        <%- post.content || '<p>No content available.</p>' %>
                            <!-- using <%- %> to render raw HTML for content -->
                    </article>
                    <% } %>
        </div>

        <!-- ══════ FOOTER ══════ -->
        <%- include('partials/footer') %>
</body>

</html>