<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="../logo.png" />
    <title>Contact Us — urbox.ai | Shared Inbox for Teams</title>
    <meta name="description"
        content="Get in touch with the urbox.ai team. We're here to help with questions about pricing, features, onboarding, or anything else." />
    <link rel="canonical" href="https://urbox.ai/contact/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="urbox.ai" />
    <meta property="og:url" content="https://urbox.ai/contact/" />
    <meta property="og:title" content="Contact Us — urbox.ai" />
    <meta property="og:description"
        content="Get in touch with the urbox.ai team. We're here to help with questions about pricing, features, and onboarding." />
    <meta property="og:image" content="https://urbox.ai/logo.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap"
        rel="stylesheet" />

    <!-- Styles -->
    <link rel="stylesheet" href="../styles/base.css" />
    <link rel="stylesheet" href="../sections/navbar/navbar.css" />
    <link rel="stylesheet" href="../blog/blog.css" />
    <link rel="stylesheet" href="./contact.css" />

    <!-- Analytics -->
    <script type="module" src="../scripts/analytics.js"></script>
</head>

<body>

    <!-- ══════════════════ NAVBAR ══════════════════ -->
    <%- include('../partials/header') %>

        <main>

            <!-- ══════════════════ HERO ══════════════════ -->
            <section class="contact-hero">
                <div class="contact-hero-glow contact-hero-glow-1"></div>
                <div class="contact-hero-glow contact-hero-glow-2"></div>
                <div class="contact-hero-inner">
                    <div class="contact-eyebrow">
                        <span class="eyebrow-dot"></span>
                        Talk to us
                    </div>
                    <h1>We'd love to <em>hear</em><br />from you</h1>
                    <p class="contact-hero-sub">Whether you're curious about features, pricing, or just want a demo —
                        our
                        team
                        is ready to answer all your questions.</p>
                </div>
            </section>

            <!-- ══════════════════ MAIN GRID ══════════════════ -->
            <section class="contact-section">
                <div class="contact-grid">

                    <!-- ── Left: Info cards ── -->
                    <div class="contact-info">

                        <div class="info-card">
                            <div class="info-card-icon">
                                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path
                                        d="M2.5 5.5A1.5 1.5 0 014 4h12a1.5 1.5 0 011.5 1.5v9A1.5 1.5 0 0116 16H4a1.5 1.5 0 01-1.5-1.5v-9z"
                                        stroke="currentColor" stroke-width="1.4" />
                                    <path d="M2.5 6l7.5 5 7.5-5" stroke="currentColor" stroke-width="1.4"
                                        stroke-linecap="round" />
                                </svg>
                            </div>
                            <div class="info-card-body">
                                <h3>Email us</h3>
                                <p>Drop us a line any time and we'll respond within one business day.</p>
                                <a href="mailto:hello@urbox.ai" class="info-card-link">hello@urbox.ai</a>
                            </div>
                        </div>

                        <div class="info-card">
                            <div class="info-card-icon">
                                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.4" />
                                    <path d="M10 6v4l2.5 2.5" stroke="currentColor" stroke-width="1.4"
                                        stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="info-card-body">
                                <h3>Response time</h3>
                                <p>We typically respond within a few hours during business hours (Mon–Fri, 9am–6pm
                                    GMT+5).
                                </p>
                            </div>
                        </div>

                        <div class="info-card">
                            <div class="info-card-icon">
                                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path d="M10 2a6 6 0 100 12A6 6 0 0010 2z" stroke="currentColor"
                                        stroke-width="1.4" />
                                    <path d="M3.93 13.93L2.5 17.5l3.57-1.43M16.07 13.93L17.5 17.5l-3.57-1.43"
                                        stroke="currentColor" stroke-width="1.4" stroke-linecap="round"
                                        stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="info-card-body">
                                <h3>Book a demo</h3>
                                <p>Want a guided walkthrough? We'll show you exactly how urbox.ai fits your workflow.
                                </p>
                                <a href="https://app.urbox.ai" class="info-card-link" target="_blank"
                                    rel="noopener noreferrer">Schedule
                                    a call →</a>
                            </div>
                        </div>

                        <div class="info-card">
                            <div class="info-card-icon">
                                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path d="M4 4h12a1 1 0 011 1v7a1 1 0 01-1 1H8l-4 3V5a1 1 0 011-1z"
                                        stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="info-card-body">
                                <h3>Live chat</h3>
                                <p>Hit the chat bubble on our homepage for instant answers to common questions.</p>
                                <a href="/" class="info-card-link">Go to homepage →</a>
                            </div>
                        </div>

                    </div>

                    <!-- ── Right: Contact form ── -->
                    <div class="contact-form-wrap" id="contact-form-wrap">

                        <!-- Success state -->
                        <div class="form-success" id="form-success" aria-live="polite">
                            <div class="success-icon">
                                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                                    <circle cx="14" cy="14" r="13" stroke="#10B981" stroke-width="1.8" />
                                    <path d="M9 14l3.5 3.5L19 10" stroke="#10B981" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <h2>Message sent!</h2>
                            <p>Thanks for reaching out. We'll get back to you within one business day.</p>
                            <button class="btn-send-another" id="btn-send-another">Send another message</button>
                        </div>

                        <!-- Form -->
                        <form class="contact-form" id="contact-form" novalidate>
                            <h2>Send us a message</h2>
                            <p class="form-intro">Fill in the form and we'll get back to you shortly.</p>

                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label" for="contact-name">Full name <span
                                            class="required">*</span></label>
                                    <input class="form-input" type="text" id="contact-name" name="name"
                                        placeholder="Jane Smith" autocomplete="name" required />
                                    <span class="field-error" id="err-name"></span>
                                </div>
                                <div class="form-group">
                                    <label class="form-label" for="contact-email">Work email <span
                                            class="required">*</span></label>
                                    <input class="form-input" type="email" id="contact-email" name="email"
                                        placeholder="jane@company.com" autocomplete="email" required />
                                    <span class="field-error" id="err-email"></span>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="contact-company">Company <span
                                        class="form-optional">(optional)</span></label>
                                <input class="form-input" type="text" id="contact-company" name="company"
                                    placeholder="Acme Inc." autocomplete="organization" />
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="contact-subject">Subject <span
                                        class="required">*</span></label>
                                <div class="select-wrap">
                                    <select class="form-input form-select" id="contact-subject" name="subject" required>
                                        <option value="" disabled selected>Choose a topic…</option>
                                        <option value="General question">General question</option>
                                        <option value="Pricing & plans">Pricing &amp; plans</option>
                                        <option value="Request a demo">Request a demo</option>
                                        <option value="Technical support">Technical support</option>
                                        <option value="Partnership">Partnership</option>
                                        <option value="Other">Other</option>
                                    </select>
                                    <svg class="select-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M3.5 5.5L7 9l3.5-3.5" stroke="currentColor" stroke-width="1.5"
                                            stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </div>
                                <span class="field-error" id="err-subject"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="contact-message">Message <span
                                        class="required">*</span></label>
                                <textarea class="form-input form-textarea" id="contact-message" name="message"
                                    placeholder="Tell us what you need…" rows="5" required></textarea>
                                <span class="field-error" id="err-message"></span>
                            </div>

                            <div class="form-footer">
                                <button class="btn-submit" type="submit" id="btn-submit">
                                    <span id="btn-submit-label">Send message</span>
                                    <svg id="btn-submit-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5"
                                            stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    <svg id="btn-submit-spinner" class="spinner hidden" width="18" height="18"
                                        viewBox="0 0 18 18" fill="none">
                                        <circle cx="9" cy="9" r="7" stroke="rgba(255,255,255,0.3)" stroke-width="2" />
                                        <path d="M9 2a7 7 0 017 7" stroke="white" stroke-width="2"
                                            stroke-linecap="round" />
                                    </svg>
                                </button>
                                <p class="form-privacy">We respect your privacy and will never share your information.
                                </p>
                            </div>

                            <div class="form-error-banner hidden" id="form-error-banner" role="alert">
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.4" />
                                    <path d="M8 5v3.5M8 11v.5" stroke="currentColor" stroke-width="1.4"
                                        stroke-linecap="round" />
                                </svg>
                                <span id="form-error-msg">Something went wrong. Please try again.</span>
                            </div>
                        </form>
                    </div>

                </div>
            </section>

            <!-- ══════════════════ FAQ STRIP ══════════════════ -->
            <section class="contact-faq">
                <div class="contact-faq-inner">
                    <h2>Common questions</h2>
                    <div class="faq-strip-grid">
                        <div class="faq-strip-item">
                            <h3>Is there a free plan?</h3>
                            <p>Yes! The free plan is free forever with 3 team members and 1 shared inbox. No credit card
                                needed.</p>
                        </div>
                        <div class="faq-strip-item">
                            <h3>How quickly can I set up?</h3>
                            <p>Most teams are up and running in under 5 minutes. Connect your email and invite your team
                                —
                                that's it.</p>
                        </div>
                        <div class="faq-strip-item">
                            <h3>Do you offer refunds?</h3>
                            <p>We offer a 7-day money-back guarantee on all paid plans. No questions asked.</p>
                        </div>
                        <div class="faq-strip-item">
                            <h3>Can I cancel anytime?</h3>
                            <p>Absolutely. No contracts, no lock-in. Cancel from your account settings whenever you
                                like.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

        </main>

        <!-- ══════════════════ FOOTER ══════════════════ -->
        <%- include('../partials/footer') %>

            <script type="module" src="./contact.js"></script>
            <script src="../sections/navbar/navbar.js"></script>
</body>

</html>