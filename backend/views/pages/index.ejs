<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="logo.png" />
  <title>urbox.ai — Shared Inbox for Teams | Email, WhatsApp &amp; Team Chat</title>
  <meta name="description"
    content="urbox.ai is the all-in-one shared inbox for teams. Manage email, WhatsApp, and team chat in one place. Flat pricing, no per-user fees, free plan forever." />
  <link rel="canonical" href="https://urbox.ai/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="urbox.ai" />
  <meta property="og:url" content="https://urbox.ai/" />
  <meta property="og:title" content="urbox.ai — Shared Inbox for Teams | Email, WhatsApp &amp; Team Chat" />
  <meta property="og:description"
    content="All-in-one shared inbox for teams. Manage email, WhatsApp, and team chat in one place. Flat pricing, free plan forever, set up in 5 minutes." />
  <meta property="og:image" content="https://urbox.ai/logo.png" />
  <meta property="og:image:alt" content="urbox.ai shared inbox platform" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@urboxai" />
  <meta name="twitter:title" content="urbox.ai — Shared Inbox for Teams" />
  <meta name="twitter:description"
    content="Manage email, WhatsApp, and team chat in one place. Flat pricing, free plan forever." />
  <meta name="twitter:image" content="https://urbox.ai/logo.png" />

  <!-- Structured Data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "urbox.ai",
      "url": "https://urbox.ai",
      "logo": "https://urbox.ai/logo.png",
      "description": "All-in-one shared inbox for teams — email, WhatsApp, and team chat in one place.",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": "https://urbox.ai"
      }
    }
    </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "urbox.ai",
      "url": "https://urbox.ai",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web, iOS, Android",
      "description": "Shared inbox platform for teams. Manage email, WhatsApp, and team chat in one unified workspace.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free plan available. Paid plans from $12/month flat."
      }
    }
    </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "urbox.ai",
      "url": "https://urbox.ai",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://urbox.ai/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Is the free plan actually free — no trial?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The Free plan is free forever — no credit card required, no trial period, no expiry. You get 3 team members, 1 shared inbox, and 10 GB storage at no cost, for as long as you want."
          }
        },
        {
          "@type": "Question",
          "name": "How does flat pricing work — what if my team grows?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Unlike per-seat tools, we don't charge per user. Each plan has a maximum team size (e.g. 20 members on Silver). When you need more, just upgrade to the next tier — one flat fee, no per-user surprises."
          }
        },
        {
          "@type": "Question",
          "name": "How do I connect WhatsApp?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "WhatsApp integration is available on all paid plans. Connect your WhatsApp Business number directly from the settings panel. Incoming messages appear alongside your emails in the shared inbox."
          }
        },
        {
          "@type": "Question",
          "name": "Can I migrate from my current tool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. You can connect your existing email accounts immediately. We're building a full migration tool for conversation history — in the meantime, our support team can help guide you through the process."
          }
        },
        {
          "@type": "Question",
          "name": "Is my data secure?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All data is encrypted in transit and at rest. We follow industry-standard security practices and are pursuing SOC 2 compliance. Your team's conversations and customer data stay private."
          }
        },
        {
          "@type": "Question",
          "name": "Can I cancel anytime?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely. No long-term contracts. Cancel anytime from your account settings and you'll retain access until the end of your billing period."
          }
        }
      ]
    }
    </script>
