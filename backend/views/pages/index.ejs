              <div class="feature-name">Shared Inboxes</div>
              <div class="feature-desc">One inbox, the whole team. Assign, comment, and resolve without forwarding or
                CC chains.</div>
            </div>
            <div class="feature-item">
              <div class="feature-icon">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
